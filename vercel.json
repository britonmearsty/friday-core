{
  "version": 2,
  "builds": [
    {
      "src": "dist/worker.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/worker.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CACHE_TYPE": "memory",
    "STREMIO_ADDON": "true",
    "CORS_ORIGIN": "*",
    "MCP_ENABLED": "true",
    "PUBLIC_URL": "https://core-amber-three.vercel.app"
  }
}
